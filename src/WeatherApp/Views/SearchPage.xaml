<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WeatherApp.Core.ViewModels;assembly=WeatherApp.Core"
             xmlns:models="clr-namespace:WeatherApp.Core.Models;assembly=WeatherApp.Core"
             xmlns:controls="clr-namespace:WeatherApp.Controls"
             x:Class="WeatherApp.Views.SearchPage"
             x:Name="ThisPage"
             x:DataType="vm:SearchViewModel"
             Shell.NavBarIsVisible="False"
             SafeAreaEdges="Container">

    <Grid Padding="20,0" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="16">

        <Grid Grid.Row="0" Margin="0,28,0,8" ColumnDefinitions="*,Auto">
            <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                <Label Text="Weather" Style="{StaticResource DisplayTitleLabel}" />
                <Label Text="Search for a city" Style="{StaticResource CaptionLabel}" />
            </VerticalStackLayout>
            <Border Grid.Column="1"
                    WidthRequest="64"
                    HeightRequest="32"
                    VerticalOptions="Center"
                    StrokeThickness="0"
                    AutomationProperties.IsInAccessibleTree="True"
                    SemanticProperties.Description="Toggle light or dark theme"
                    BackgroundColor="{AppThemeBinding Light={StaticResource ThemeTrackLight}, Dark={StaticResource ThemeTrackDark}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnThemeSwitchTapped" />
                </Border.GestureRecognizers>
                <Border x:Name="ThemeThumb"
                        WidthRequest="26"
                        HeightRequest="26"
                        Margin="3"
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        StrokeThickness="0"
                        BackgroundColor="{StaticResource ThemeThumb}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="13" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.18" Radius="4" Offset="0,1" />
                    </Border.Shadow>
                    <Label Text="{Binding ThemeGlyph}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </Border>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource SearchFieldBorder}">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Label Grid.Column="0" Text="🔍" FontSize="18" VerticalOptions="Center" />
                <Entry Grid.Column="1"
                       Text="{Binding City}"
                       Placeholder="Search city…"
                       MaxLength="80"
                       IsEnabled="{Binding CanEditSearch}"
                       ReturnType="Search"
                       ReturnCommand="{Binding SearchCommand}"
                       VerticalOptions="Center" />
            </Grid>
        </Border>

        <Button Grid.Row="2"
                Text="Search"
                Command="{Binding SearchCommand}" />

        <Grid Grid.Row="3" Margin="0,8,0,0" VerticalOptions="Start">

            <VerticalStackLayout Spacing="6"
                                 IsVisible="{Binding State, Converter={StaticResource EnumToBool}, ConverterParameter=Idle}">
                <Label Text="Where to?" Style="{StaticResource Title2Label}" />
                <Label Text="Search any city to see the current conditions and a 5-day forecast."
                       Style="{StaticResource CaptionLabel}" />

                <Label Text="RECENT"
                       Style="{StaticResource SectionLabel}"
                       Margin="0,20,0,4"
                       IsVisible="{Binding HasRecents}" />
                <controls:WrapLayout Spacing="8"
                            BindableLayout.ItemsSource="{Binding Recents}"
                            IsVisible="{Binding HasRecents}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:GeocodingResult">
                            <Border Style="{StaticResource ChipBorder}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={x:Reference ThisPage}, Path=ViewModel.OpenRecentCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding Name}" />
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </controls:WrapLayout>
            </VerticalStackLayout>

            <ActivityIndicator Margin="0,24,0,0"
                               HorizontalOptions="Center"
                               IsRunning="{Binding State, Converter={StaticResource EnumToBool}, ConverterParameter=Loading}"
                               IsVisible="{Binding State, Converter={StaticResource EnumToBool}, ConverterParameter=Loading}" />

            <VerticalStackLayout Spacing="6"
                                 IsVisible="{Binding State, Converter={StaticResource EnumToBool}, ConverterParameter=Empty}">
                <Label Text="🔎" FontSize="40" HorizontalOptions="Center" />
                <Label Text="{Binding City, StringFormat='No match for “{0}”.'}"
                       Style="{StaticResource Title2Label}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
                <Label Text="Try a different spelling."
                       Style="{StaticResource CaptionLabel}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10"
                                 IsVisible="{Binding State, Converter={StaticResource EnumToBool}, ConverterParameter=Error}">
                <Label Text="☁️" FontSize="40" HorizontalOptions="Center" />
                <Label Text="{Binding ErrorMessage}"
                       Style="{StaticResource CaptionLabel}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
                <Button Text="Retry"
                        Command="{Binding SearchCommand}"
                        WidthRequest="160"
                        HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
