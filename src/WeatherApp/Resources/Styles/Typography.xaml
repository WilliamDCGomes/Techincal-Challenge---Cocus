<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <x:Double x:Key="SizeHero">88</x:Double>
    <x:Double x:Key="SizeDisplay">34</x:Double>
    <x:Double x:Key="SizeTitle2">22</x:Double>
    <x:Double x:Key="SizeRow">16</x:Double>
    <x:Double x:Key="SizeCaption">15</x:Double>
    <x:Double x:Key="SizeSection">13</x:Double>

    <OnPlatform x:Key="HeroFontFamily" x:TypeArguments="x:String" Default="OpenSansRegular">
        <On Platform="Android" Value="sans-serif-thin" />
    </OnPlatform>

    <Style x:Key="BaseLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="{StaticResource SizeRow}" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource LightTextPrimary}, Dark={StaticResource DarkTextPrimary}}" />
    </Style>

    <Style x:Key="HeroTempLabel" TargetType="Label" BasedOn="{StaticResource BaseLabel}">
        <Setter Property="FontFamily" Value="{StaticResource HeroFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource SizeHero}" />
        <Setter Property="LineBreakMode" Value="NoWrap" />
    </Style>

    <Style x:Key="DisplayTitleLabel" TargetType="Label" BasedOn="{StaticResource BaseLabel}">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="{StaticResource SizeDisplay}" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="Title2Label" TargetType="Label" BasedOn="{StaticResource BaseLabel}">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="{StaticResource SizeTitle2}" />
    </Style>

    <Style x:Key="CaptionLabel" TargetType="Label" BasedOn="{StaticResource BaseLabel}">
        <Setter Property="FontSize" Value="{StaticResource SizeCaption}" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource LightTextSecondary}, Dark={StaticResource DarkTextSecondary}}" />
    </Style>

    <Style x:Key="SectionLabel" TargetType="Label" BasedOn="{StaticResource BaseLabel}">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="{StaticResource SizeSection}" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource LightTextSecondary}, Dark={StaticResource DarkTextSecondary}}" />
    </Style>

</ResourceDictionary>
